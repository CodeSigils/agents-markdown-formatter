{
  "name": "agents-markdown-formatter",
  "version": "1.0.0",
  "description": "Formatter-first GFM+MDX skill for AI agents powered by Oxc oxfmt",
  "private": true,
  "scripts": {
    "test": "node skills/markdown-formatter/scripts/check-all.js",
    "test:verbose": "node skills/markdown-formatter/scripts/check-all.js test/fixtures/",
    "test:unit": "node --test test/unit/*.test.js",
    "test:integration": "node --test test/integration/*.test.js",
    "format": "node skills/markdown-formatter/src/index.js --fix --all .",
    "format:check": "node skills/markdown-formatter/src/index.js --check --all .",
    "verify": "node skills/markdown-formatter/src/index.js --verify --all .",
    "guard": "node skills/markdown-formatter/src/index.js --guard --all ."
  },
  "devDependencies": {
    "oxfmt": "0.51.0"
  },
  "engines": {
    "node": ">=20"
  }
}
